PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=root
DB_NAME=mrmed_db

# JWT Configuration
JWT_SECRET=supersecretjwtkeyforauth
JWT_REFRESH_SECRET=supersecretrefreshjwtkeyforauth
JWT_EXPIRE=1h
JWT_REFRESH_EXPIRE=7d

# Redis Configuration
REDIS_URL=redis://127.0.0.1:6379

# Cloudinary
CLOUDINARY_CLOUD_NAME=mock_cloud
CLOUDINARY_API_KEY=mock_key
CLOUDINARY_API_SECRET=mock_secret

# AWS S3
AWS_ACCESS_KEY_ID=mock_aws_key
AWS_SECRET_ACCESS_KEY=mock_aws_secret
AWS_REGION=us-east-1
AWS_BUCKET_NAME=mrmed-prescriptions

# Razorpay
RAZORPAY_KEY_ID=rzp_test_mockkeyid123
RAZORPAY_KEY_SECRET=mockkeysecret456
