{
  "name": "dosebox-monolith",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only server.ts",
    "build": "next build && tsc --project tsconfig.server.json",
    "start": "NODE_ENV=production node dist/server.js",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:seed": "npx sequelize-cli db:seed:all"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.2.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.7",
    "sequelize": "^6.37.3",
    "sqlite3": "^5.1.7",
    "redis": "^4.6.13",
    "cloudinary": "^1.41.0",
    "pdfkit": "^0.15.0",
    "zod": "^3.23.8",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "axios": "^1.6.8",
    "clsx": "^2.1.1",
    "framer-motion": "^11.2.6",
    "lucide-react": "^0.379.0",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.3.0",
    "dotenv": "^16.4.5",
